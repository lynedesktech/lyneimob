# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publica-supabase
SUPABASE_SERVICE_ROLE_KEY=sua-chave-admin-supabase

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (IA — usada em Server Actions, nunca expor no browser)
OPENAI_API_KEY=sk-proj-xxx


# Upstash Redis (cache e memoria do agente WhatsApp)
UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu-token-redis

# Resend (email transacional)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=LyneImob <noreply@seudominio.com>

# Agente Railway (OBRIGATORIA — webhook WhatsApp aponta pra ca)
AGENT_RAILWAY_URL=https://seu-agente.up.railway.app

# Cron (segredo para proteger endpoints de cron)
CRON_SECRET=seu-segredo-cron

# OBRIGATORIA — secret para auth de endpoints /api/interno/*
# Gerar com: openssl rand -hex 32
# Mesmo valor deve ser configurado no Railway (env do agente Python)
INTERNAL_API_SECRET=seu-secret-interno-aleatorio-32-chars
