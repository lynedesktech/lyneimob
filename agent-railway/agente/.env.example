# ============================================================
# LyneMob Agent — Variaveis de ambiente
# Copie para .env e preencha com seus valores
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
WHISPER_MODEL=whisper-1
VISION_MODEL=gpt-4o-mini

# --- Redis (Railway provisiona automaticamente) ---
REDIS_URL=redis://default:senha@host:porta

# --- Supabase (mesmo banco do LyneMob) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # Service role key (nao anon key)

# --- UAZAPI (fallback se webhook nao trouxer credenciais) ---
UAZAPI_DEFAULT_URL=https://api.uazapi.com
UAZAPI_DEFAULT_TOKEN=token-da-instancia

# --- Buffer ---
BUFFER_WAIT_SECONDS=20
BUFFER_TTL_SECONDS=300

# --- Anti-bloqueio ---
RATE_LIMIT_PER_CONTACT_PER_MINUTE=8
RATE_LIMIT_GLOBAL_PER_MINUTE=60
TYPING_INDICATOR_MIN_MS=1500
TYPING_INDICATOR_MAX_MS=6000
MIN_DELAY_BETWEEN_SEGMENTS=1.0
MAX_DELAY_BETWEEN_SEGMENTS=3.0
COOLDOWN_AFTER_BURST_SECONDS=5.0
BURST_THRESHOLD=5
MIN_SESSION_GAP_SECONDS=2.0

# --- Horario de funcionamento (desativado por padrao — usa config do banco) ---
BUSINESS_HOURS_ENABLED=false
BUSINESS_HOURS_START=7
BUSINESS_HOURS_END=19
